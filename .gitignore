# Ignore local AI state and temp files
.beads/
.agent/memory/session-handover.md
.agent/memory/current-task.md

# Common build and dependency artifacts
node_modules/
.venv/
target/
dist/
build/
docs/build/

# AI Toolbox client routers (generated locally by bootstrap)
# Note: .gitignore has no effect on already-tracked files.
# These files ARE committed as reference templates but local edits
# should not be committed back (use bootstrap to regenerate).
# Anchored to root to avoid matching template files in .agent/templates/clients/

# Locally-generated JSON config (not committed)
/.claude.json
/.aider.conf.yml

# Standard-Tier router files (generated by bootstrap, local edits preserved)
/.cursorrules
/.clinerules
/.windsurfrules
