# Ignore local AI state and temp files
/.beads/
/.agent/memory/session-handover.md
/.agent/memory/current-task.md
/.agent/memory/.tool-stats.json
*.pyc
__pycache__/

# Local IDE config
/.qwen/
/.claude/

# Local client configs (may contain hooks/tokens)
.qwen/settings.json
.codex/
opencode.json
opencode.jsonc

# Common build and dependency artifacts
/node_modules/
/.venv/
/target/
/dist/
/build/
/docs/build/

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key

# AI tool artifacts
*.log
.aider.chat.history.md
.cursorhistory
