{
  "_comment": "Qwen Code MCP Configuration — add to your Qwen Code MCP settings",
  "_usage": "Each server uses npx for zero-install setup. Copy to Qwen Code MCP config.",
  "_source": "Based on .agent/templates/mcp/mcp-configs.json (developer profile)",

  "mcpServers": {
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@1.2.0"],
      "env": {}
    },
    "sequential-thinking": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking@0.1.0"],
      "env": {}
    },
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem@0.6.2", "./src", "./docs", "./examples", ".agent/rules", ".agent/workflows"],
      "env": {}
    },
    "fetch": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-fetch@0.4.0"],
      "env": {}
    }
  }
}
